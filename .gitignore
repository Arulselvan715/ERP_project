# Version control ignore rules for Shiv ERP Monorepo

# Python (Backend)
backend/.venv/
backend/venv/
backend/ENV/
backend/__pycache__/
backend/**/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/*.db
backend/*.db-journal

# Node.js (Frontend)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.eslintcache
frontend/*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
